{
  "name": "@star-atlas-agent/mcp-staratlas-server",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for Star Atlas and Solana blockchain integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "bin": {
    "staratlas-mcp-server": "dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "@solana/web3.js": "^1.95.8",
    "@staratlas/data-source": "^0.7.1",
    "@staratlas/sage": "^1.8.10",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "star-atlas",
    "solana",
    "blockchain",
    "gaming"
  ]
}
